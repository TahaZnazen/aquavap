---
interface Props {
  beforeLabel?: string;
  afterLabel?: string;
  title?: string;
  before: string;
  after: string;
}

const { beforeLabel = "Avant", afterLabel = "Après", title = "", before, after } = Astro.props;
---

<div class="before-after-slider relative rounded-2xl overflow-hidden shadow-lg group cursor-col-resize select-none" data-slider>
  <!-- Before image -->
  <div class="aspect-[4/3] bg-gray-200 relative">
    <img
      src={`/images/before-after/${before}.png`}
      alt={`Avant - ${title}`}
      class="w-full h-full object-cover"
    />
  </div>

  <!-- After overlay (clipped) -->
  <div
    class="slider-after absolute inset-0 overflow-hidden"
    style="clip-path: inset(0 0 0 50%)"
    data-after
  >
    <img
      src={`/images/before-after/${after}.png`}
      alt={`Après - ${title}`}
      class="w-full h-full object-cover"
    />
  </div>

  <!-- Labels -->
  <span class="absolute top-4 left-4 px-3 py-1 bg-red-500/80 text-white text-xs font-bold rounded-full backdrop-blur-sm">
    {beforeLabel}
  </span>
  <span class="absolute top-4 right-4 px-3 py-1 bg-success/80 text-white text-xs font-bold rounded-full backdrop-blur-sm">
    {afterLabel}
  </span>

  <!-- Slider handle -->
  <div
    class="slider-handle absolute top-0 bottom-0 w-1 bg-white shadow-lg cursor-col-resize"
    style="left: 50%"
    data-handle
  >
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 bg-white rounded-full shadow-xl flex items-center justify-center">
      <!-- Feather: chevron-left + chevron-right spaced -->
      <svg class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 17 4 12 9 7" />
        <polyline points="15 7 20 12 15 17" />
      </svg>
    </div>
  </div>

  {title && (
    <div class="absolute bottom-4 left-4 right-4 text-center">
      <span class="px-4 py-2 bg-black/50 text-white text-sm font-medium rounded-full backdrop-blur-sm">
        {title}
      </span>
    </div>
  )}
</div>

<script>
  document.querySelectorAll("[data-slider]").forEach((slider) => {
    const afterEl = slider.querySelector("[data-after]") as HTMLElement;
    const handle = slider.querySelector("[data-handle]") as HTMLElement;
    let isDragging = false;

    function updatePosition(x: number) {
      const rect = (slider as HTMLElement).getBoundingClientRect();
      let percent = ((x - rect.left) / rect.width) * 100;
      percent = Math.max(0, Math.min(100, percent));
      afterEl.style.clipPath = `inset(0 0 0 ${percent}%)`;
      handle.style.left = `${percent}%`;
    }

    slider.addEventListener("mousedown", (e) => {
      isDragging = true;
      updatePosition((e as MouseEvent).clientX);
    });
    document.addEventListener("mousemove", (e) => {
      if (isDragging) updatePosition((e as MouseEvent).clientX);
    });
    document.addEventListener("mouseup", () => (isDragging = false));

    slider.addEventListener("touchstart", (e) => {
      isDragging = true;
      updatePosition((e as TouchEvent).touches[0].clientX);
    }, { passive: true });
    document.addEventListener("touchmove", (e) => {
      if (isDragging) updatePosition((e as TouchEvent).touches[0].clientX);
    });
    document.addEventListener("touchend", () => (isDragging = false));
  });
</script>
