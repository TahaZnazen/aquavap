---
import { siteConfig } from "../data/site";

const reels = [
  { src: "/videos/reel1.mp4", title: "Nettoyage canapé" },
  { src: "/videos/reel2.mp4", title: "Nettoyage voiture" },
  { src: "/videos/reel3.mp4", title: "Tapis — Avant/Après" },
  { src: "/videos/reel4.mp4", title: "Cuisine professionnelle" },
  { src: "/videos/reel5.mp4", title: "Mosquée" },
  { src: "/videos/reel6.mp4", title: "Nettoyage vapeur" },
   { src: "/videos/reel7.mp4", title: "Nettoyage vapeur" },
    { src: "/videos/reel8.mp4", title: "Nettoyage vapeur" },
];
---

<section id="reels" class="py-24 bg-background">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-primary/10 text-primary font-semibold text-sm rounded-full mb-4">
        Suivez-nous
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-text-primary mb-4">
        Nos dernières
        <span class="text-primary">vidéos</span>
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">
        Découvrez nos interventions en vidéo. Des résultats qui parlent d'eux-mêmes.
      </p>
    </div>

    <!-- Carousel -->
    <div class="relative">

      <!-- Prev button -->
      <button
        id="reels-prev"
        class="absolute -left-4 lg:-left-6 top-1/2 -translate-y-1/2 z-10 w-12 h-12 bg-white rounded-full shadow-lg flex items-center justify-center hover:bg-primary hover:text-white text-text-secondary transition-all duration-300 hover:scale-110 disabled:opacity-30 disabled:pointer-events-none"
        aria-label="Précédent"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6" />
        </svg>
      </button>

      <!-- Track -->
      <div class="overflow-hidden">
        <div id="reels-track" class="flex transition-transform duration-500 ease-in-out" style="gap: 2rem;">
          {reels.map((reel, i) => (
            <div class="reel-slide flex-shrink-0">
              <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 group">
                <!-- Video wrapper — portrait 9:16 -->
                <div class="aspect-[9/16] relative bg-black">
                  <video
                    src={reel.src}
                    class="absolute inset-0 w-full h-full object-cover"
                    loop
                    playsinline
                    preload="metadata"
                    data-reel-video
                  ></video>

                  <!-- Mute button -->
                  <button
                    class="reel-mute-btn absolute top-3 right-3 z-10 w-9 h-9 bg-black/50 hover:bg-black/70 rounded-full flex items-center justify-center transition-colors backdrop-blur-sm"
                    aria-label="Couper le son"
                    data-muted="true"
                  >
                    <!-- Muted icon (shown by default since videos start muted) -->
                    <span class="muted-icon flex items-center justify-center">
                      <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M16.5 12A4.5 4.5 0 0014 7.97v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51A8.796 8.796 0 0021 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06A8.99 8.99 0 0017.73 18L19 19.27 20.27 18 5.27 3 4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
                      </svg>
                    </span>
                    <!-- Unmuted icon (hidden by default) -->
                    <span class="unmuted-icon hidden items-center justify-center">
                      <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0014 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
                      </svg>
                    </span>
                  </button>

                  <!-- Play / Pause overlay -->
                  <button
                    class="reel-play-btn absolute inset-0 w-full h-full flex items-center justify-center bg-black/20 hover:bg-black/30 transition-colors group/btn"
                    aria-label="Lecture"
                    data-playing="false"
                  >
                    <!-- Play icon -->
                    <span class="play-icon w-16 h-16 bg-white/90 rounded-full flex items-center justify-center shadow-xl group-hover/btn:scale-110 transition-transform">
                      <svg class="w-7 h-7 text-primary translate-x-0.5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z" />
                      </svg>
                    </span>
                    <!-- Pause icon (hidden by default) -->
                    <span class="pause-icon w-16 h-16 bg-white/90 rounded-full hidden items-center justify-center shadow-xl group-hover/btn:scale-110 transition-transform">
                      <svg class="w-7 h-7 text-primary" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" />
                      </svg>
                    </span>
                  </button>
                </div>

             
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Next button -->
      <button
        id="reels-next"
        class="absolute -right-4 lg:-right-6 top-1/2 -translate-y-1/2 z-10 w-12 h-12 bg-white rounded-full shadow-lg flex items-center justify-center hover:bg-primary hover:text-white text-text-secondary transition-all duration-300 hover:scale-110 disabled:opacity-30 disabled:pointer-events-none"
        aria-label="Suivant"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </button>

      <!-- Dots -->
      <div id="reels-dots" class="flex items-center justify-center gap-2 mt-8"></div>
    </div>

    <!-- Social links -->
    <div class="flex flex-wrap items-center justify-center gap-4 mt-12">
      <a href={siteConfig.socials.instagram} target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-purple-500 to-pink-500 text-white font-semibold rounded-full hover:opacity-90 transition-opacity shadow-lg">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
        </svg>
        Instagram
      </a>
      <a href={siteConfig.socials.tiktok} target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 bg-black text-white font-semibold rounded-full hover:opacity-90 transition-opacity shadow-lg">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.48 6.3 6.3 0 001.86-4.49V8.75a8.26 8.26 0 004.84 1.56v-3.5a4.84 4.84 0 01-1.12-.12z" />
        </svg>
        TikTok
      </a>
      <a href={siteConfig.socials.facebook} target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white font-semibold rounded-full hover:opacity-90 transition-opacity shadow-lg">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
        </svg>
        Facebook
      </a>
    </div>

  </div>
</section>

<script>
  // ── Carousel ──────────────────────────────────────────────
  const track    = document.getElementById("reels-track")! as HTMLElement;
  const prevBtn  = document.getElementById("reels-prev")!  as HTMLButtonElement;
  const nextBtn  = document.getElementById("reels-next")!  as HTMLButtonElement;
  const dotsWrap = document.getElementById("reels-dots")!  as HTMLElement;
  const slides   = track.querySelectorAll<HTMLElement>(".reel-slide");
  const gap      = 32;
  let current    = 0;

  function getVisible() {
    if (window.innerWidth >= 1024) return 3;
    if (window.innerWidth >= 640)  return 2;
    return 1;
  }

  function getMaxIndex() {
    return Math.max(0, slides.length - getVisible());
  }

  function updateCarousel() {
    const visible      = getVisible();
    const containerW   = track.parentElement!.clientWidth;
    const slideW       = (containerW - gap * (visible - 1)) / visible;

    slides.forEach(s => s.style.width = `${slideW}px`);
    track.style.transform = `translateX(-${current * (slideW + gap)}px)`;

    prevBtn.disabled = current === 0;
    nextBtn.disabled = current >= getMaxIndex();

    // Dots
    dotsWrap.innerHTML = "";
    for (let i = 0; i <= getMaxIndex(); i++) {
      const dot = document.createElement("button");
      dot.className = `h-2.5 rounded-full transition-all duration-300 ${
        i === current ? "bg-primary w-8" : "bg-gray-300 hover:bg-gray-400 w-2.5"
      }`;
      dot.setAttribute("aria-label", `Page ${i + 1}`);
      dot.addEventListener("click", () => { current = i; updateCarousel(); });
      dotsWrap.appendChild(dot);
    }
  }

  prevBtn.addEventListener("click", () => { if (current > 0) { current--; updateCarousel(); } });
  nextBtn.addEventListener("click", () => { if (current < getMaxIndex()) { current++; updateCarousel(); } });
  window.addEventListener("resize", () => {
    if (current > getMaxIndex()) current = getMaxIndex();
    updateCarousel();
  });
  updateCarousel();

  // ── Play / Pause ──────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>(".reel-play-btn").forEach(btn => {
    const video     = btn.parentElement!.querySelector<HTMLVideoElement>("[data-reel-video]")!;
    const playIcon  = btn.querySelector<HTMLElement>(".play-icon")!;
    const pauseIcon = btn.querySelector<HTMLElement>(".pause-icon")!;

    btn.addEventListener("click", () => {
      const playing = btn.dataset.playing === "true";

      if (playing) {
        video.pause();
        btn.dataset.playing = "false";
        playIcon.classList.remove("hidden");
        playIcon.classList.add("flex");
        pauseIcon.classList.add("hidden");
        pauseIcon.classList.remove("flex");
      } else {
        // Pause all other videos first
        document.querySelectorAll<HTMLVideoElement>("[data-reel-video]").forEach(v => {
          if (v !== video) {
            v.pause();
            const otherBtn = v.parentElement!.querySelector<HTMLButtonElement>(".reel-play-btn");
            if (otherBtn) {
              otherBtn.dataset.playing = "false";
              otherBtn.querySelector<HTMLElement>(".play-icon")!.classList.remove("hidden");
              otherBtn.querySelector<HTMLElement>(".play-icon")!.classList.add("flex");
              otherBtn.querySelector<HTMLElement>(".pause-icon")!.classList.add("hidden");
              otherBtn.querySelector<HTMLElement>(".pause-icon")!.classList.remove("flex");
            }
          }
        });

        video.play();
        btn.dataset.playing = "true";
        playIcon.classList.add("hidden");
        playIcon.classList.remove("flex");
        pauseIcon.classList.remove("hidden");
        pauseIcon.classList.add("flex");
      }
    });

    // Reset button when video ends
    video.addEventListener("ended", () => {
      btn.dataset.playing = "false";
      playIcon.classList.remove("hidden");
      playIcon.classList.add("flex");
      pauseIcon.classList.add("hidden");
      pauseIcon.classList.remove("flex");
    });
  });

  // ── Mute / Unmute ─────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>(".reel-mute-btn").forEach(muteBtn => {
    // video is the next sibling of the mute button's parent wrapper — walk up to find it
    const wrapper    = muteBtn.parentElement!;
    const video      = wrapper.querySelector<HTMLVideoElement>("[data-reel-video]")!;
    const mutedIcon  = muteBtn.querySelector<HTMLElement>(".muted-icon")!;
    const unmutedIcon = muteBtn.querySelector<HTMLElement>(".unmuted-icon")!;

    // Videos start muted
    video.muted = true;

    muteBtn.addEventListener("click", (e) => {
      e.stopPropagation(); // don't trigger play/pause
      video.muted = !video.muted;
      muteBtn.dataset.muted = String(video.muted);

      if (video.muted) {
        mutedIcon.classList.remove("hidden");
        mutedIcon.classList.add("flex");
        unmutedIcon.classList.add("hidden");
        unmutedIcon.classList.remove("flex");
      } else {
        mutedIcon.classList.add("hidden");
        mutedIcon.classList.remove("flex");
        unmutedIcon.classList.remove("hidden");
        unmutedIcon.classList.add("flex");
      }
    });
  });
</script>
