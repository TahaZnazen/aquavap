---
import { siteConfig } from "../data/site";
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="#" class="flex items-center gap-2 group">
        <img
          src="/images/logoWhite.png"
          alt={siteConfig.name}
          class="h-10 w-auto group-hover:scale-110 transition-transform nav-logo-white"
        />
        <img
          src="/images/logo.png"
          alt={siteConfig.name}
          class="h-10 w-auto group-hover:scale-110 transition-transform nav-logo-dark hidden"
        />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#services" class="nav-link text-sm font-medium hover:text-primary transition-colors">Nos Services</a>
        <a href="#gallery" class="nav-link text-sm font-medium hover:text-primary transition-colors">Galerie</a>
        <a href="#how-it-works" class="nav-link text-sm font-medium hover:text-primary transition-colors">Comment ça marche</a>
        <a href="#testimonials" class="nav-link text-sm font-medium hover:text-primary transition-colors">Avis</a>
        <a href="#booking" class="nav-link text-sm font-medium hover:text-primary transition-colors">Réservation</a>
      </div>

      <!-- CTA -->
      <div class="hidden md:flex items-center gap-3">
        <a
          href={`tel:${siteConfig.phoneRaw}`}
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent text-white font-semibold rounded-full hover:bg-accent-dark transition-all hover:-translate-y-0.5 shadow-lg text-sm"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Appelez-nous
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg hover:bg-white/10 transition-colors"
        aria-label="Menu"
      >
        <svg class="w-6 h-6 nav-text-color" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-white/95 backdrop-blur-md border-t border-gray-100"
  >
    <div class="px-4 py-4 space-y-3">
      <a href="#services" class="block text-text-primary font-medium py-2 hover:text-primary mobile-link">Nos Services</a>
      <a href="#gallery" class="block text-text-primary font-medium py-2 hover:text-primary mobile-link">Galerie</a>
      <a href="#how-it-works" class="block text-text-primary font-medium py-2 hover:text-primary mobile-link">Comment ça marche</a>
      <a href="#testimonials" class="block text-text-primary font-medium py-2 hover:text-primary mobile-link">Avis</a>
      <a href="#booking" class="block text-text-primary font-medium py-2 hover:text-primary mobile-link">Réservation</a>
      <a
        href={`tel:${siteConfig.phoneRaw}`}
        class="block text-center px-5 py-3 bg-accent text-white font-semibold rounded-full hover:bg-accent-dark transition-all"
      >
        Appelez-nous
      </a>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar")!;
  const mobileBtn = document.getElementById("mobile-menu-btn")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const navLinks = document.querySelectorAll(".nav-link");

  const logoWhite = navbar.querySelector(".nav-logo-white") as HTMLElement;
  const logoDark = navbar.querySelector(".nav-logo-dark") as HTMLElement;

  // Scroll effect
  function updateNav() {
    if (window.scrollY > 50) {
      navbar.classList.add("bg-white/95", "backdrop-blur-md", "shadow-md");
      navbar.classList.remove("bg-transparent");
      navbar.querySelectorAll(".nav-text-color").forEach((el) => {
        el.classList.add("text-text-primary");
        el.classList.remove("text-white");
      });
      navLinks.forEach((el) => {
        el.classList.add("text-text-secondary");
        el.classList.remove("text-white/90");
      });
      logoWhite.classList.add("hidden");
      logoDark.classList.remove("hidden");
    } else {
      navbar.classList.remove("bg-white/95", "backdrop-blur-md", "shadow-md");
      navbar.classList.add("bg-transparent");
      navbar.querySelectorAll(".nav-text-color").forEach((el) => {
        el.classList.remove("text-text-primary");
        el.classList.add("text-white");
      });
      navLinks.forEach((el) => {
        el.classList.remove("text-text-secondary");
        el.classList.add("text-white/90");
      });
      logoWhite.classList.remove("hidden");
      logoDark.classList.add("hidden");
    }
  }
  updateNav();
  window.addEventListener("scroll", updateNav);

  // Mobile menu toggle
  mobileBtn.addEventListener("click", () => {
    mobileMenu.classList.toggle("hidden");
  });

  // Close mobile menu on link click
  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
    });
  });
</script>
