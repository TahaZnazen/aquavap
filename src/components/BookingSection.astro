---
import CTAButton from "./CTAButton.astro";
import { siteConfig } from "../data/site";

const whatsappUrl = `https://wa.me/${siteConfig.whatsapp}?text=${encodeURIComponent(siteConfig.whatsappMessage)}`;
---

<section id="booking" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span
        class="inline-block px-4 py-1.5 bg-primary/10 text-primary font-semibold text-sm rounded-full mb-4"
      >
        Devis Gratuit
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-text-primary mb-4">
        Obtenez votre
        <span class="text-primary">devis gratuit</span>
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">
        Remplissez le formulaire ou contactez-nous directement. Nous répondons en moins de 30 minutes.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

      <!-- Contact Form -->
      <div class="bg-background rounded-2xl p-8 border border-gray-100 shadow-sm">
        <h3 class="text-xl font-bold text-text-primary mb-6 flex items-center gap-2">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Demander un devis
        </h3>

        <form id="devis-form" class="space-y-5">
          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-semibold text-text-primary mb-1.5">
              Nom complet <span class="text-primary">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Votre nom"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-text-primary placeholder-gray-400 bg-white"
            />
          </div>

          <!-- Phone -->
          <div>
            <label for="phone" class="block text-sm font-semibold text-text-primary mb-1.5">
              Téléphone <span class="text-primary">*</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              placeholder="+216 XX XXX XXX"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-text-primary placeholder-gray-400 bg-white"
            />
          </div>

          <!-- Service -->
          <div>
            <label for="service" class="block text-sm font-semibold text-text-primary mb-1.5">
              Service souhaité
            </label>
            <select
              id="service"
              name="service"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-text-primary bg-white"
            >
              <option value="">Sélectionnez un service...</option>
              <option>Nettoyage Vapeur</option>
              <option>Canapés & Salons</option>
              <option>Tapis & Moquettes</option>
              <option>Rideaux & Matelas</option>
              <option>Entreprise & Bureaux</option>
              <option>Mosquée</option>
              <option>Cuisine & Dégraissage</option>
              <option>Théâtre & Cinéma</option>
              <option>Voitures</option>
              <option>Autre</option>
            </select>
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="block text-sm font-semibold text-text-primary mb-1.5">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Décrivez votre besoin (surface, type de nettoyage, localisation...)"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-text-primary placeholder-gray-400 bg-white resize-none"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5 flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Envoyer via WhatsApp
          </button>

          <p class="text-xs text-text-secondary text-center">
            Votre demande sera envoyée directement sur WhatsApp pour une réponse rapide.
          </p>
        </form>
      </div>

      <!-- Contact info -->
      <div class="space-y-6">

        <!-- WhatsApp direct -->
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="block bg-green-50 rounded-2xl p-6 border border-green-100 hover:shadow-lg transition-all duration-300 hover:-translate-y-1 group"
        >
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-green-500 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-text-primary">WhatsApp direct</h3>
              <p class="text-text-secondary text-sm">Réponse rapide, envoyez-nous un message</p>
            </div>
            <svg class="w-5 h-5 text-text-secondary ml-auto group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>

        <!-- Phone -->
        <a
          href={`tel:${siteConfig.phoneRaw}`}
          class="block bg-primary/5 rounded-2xl p-6 border border-primary/10 hover:shadow-lg transition-all duration-300 hover:-translate-y-1 group"
        >
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-primary rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-text-primary">Téléphone</h3>
              <p class="text-text-secondary text-sm">{siteConfig.phone}</p>
            </div>
            <svg class="w-5 h-5 text-text-secondary ml-auto group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>

        <!-- Address & Hours -->
        <div class="bg-background rounded-2xl p-6 border border-gray-100">
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <p class="font-semibold text-text-primary text-sm">Adresse</p>
                <p class="text-text-secondary text-sm">{siteConfig.address}</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-semibold text-text-primary text-sm">Horaires</p>
                <p class="text-text-secondary text-sm">{siteConfig.hours}</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="font-semibold text-text-primary text-sm">Email</p>
                <p class="text-text-secondary text-sm">{siteConfig.email}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Trust badges -->
        <div class="grid grid-cols-3 gap-3">
          {[
            { icon: "⚡", label: "Réponse < 30min" },
            { icon: "🛡️", label: "Devis gratuit" },
            { icon: "✅", label: "Sans engagement" },
          ].map(b => (
            <div class="bg-background rounded-xl p-3 border border-gray-100 text-center">
              <div class="text-2xl mb-1">{b.icon}</div>
              <p class="text-xs font-semibold text-text-secondary">{b.label}</p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  const WHATSAPP_NUMBER = "21622772171";

  document.getElementById('devis-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;

    const name    = (form.querySelector('#name') as HTMLInputElement).value.trim();
    const phone   = (form.querySelector('#phone') as HTMLInputElement).value.trim();
    const service = (form.querySelector('#service') as HTMLSelectElement).value;
    const message = (form.querySelector('#message') as HTMLTextAreaElement).value.trim();

    let whatsappMsg = `Bonjour, je souhaite un devis.\n\n`;
    whatsappMsg += `*Nom :* ${name}\n`;
    whatsappMsg += `*Téléphone :* ${phone}\n`;
    if (service) whatsappMsg += `*Service :* ${service}\n`;
    if (message) whatsappMsg += `*Message :* ${message}\n`;

    const whatsappLink = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(whatsappMsg)}`;
    window.open(whatsappLink, "_blank");
  });
</script>
