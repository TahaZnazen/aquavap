---
import CTAButton from "./CTAButton.astro";
import { siteConfig } from "../data/site";
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-secondary via-primary-dark to-primary">
    <!-- Placeholder for hero image — replace the div below with an <img> -->
    <div class="absolute inset-0 bg-[url('/images/hero.png')] bg-cover bg-center opacity-60"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-secondary/60 via-secondary/20 to-transparent"></div>
  </div>

  <!-- Decorative elements -->
  <div class="absolute top-20 right-10 w-72 h-72 bg-primary-light/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 left-10 w-96 h-96 bg-accent/10 rounded-full blur-3xl"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 text-center pt-20">
    <!-- Badge -->
    <div
      class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-md rounded-full border border-white/20 mb-8 animate-fade-in"
    >
      <span class="w-2 h-2 bg-success rounded-full animate-pulse"></span>
      <span class="text-white/90 text-sm font-medium">Service professionnel en Tunisie</span>
    </div>

    <h1
      class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-6 animate-fade-in-up"
    >
      Nettoyage à la
      <span  >Vapeur</span>
      <br />Professionnel
    </h1>

    <p
      class="text-lg sm:text-xl text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-in-up-delay"
    >
      {siteConfig.tagline}. Canapés, voitures, tapis, rideaux — nous redonnons vie à vos espaces avec la puissance de la vapeur.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up-delay-2">
      <CTAButton href="#booking" variant="primary" size="lg">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        Réserver maintenant
      </CTAButton>
      <CTAButton href="#gallery" variant="outline" size="lg">
        Voir nos résultats
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </CTAButton>
    </div>

    <!-- Trust indicators -->
    <div class="flex flex-wrap items-center justify-center gap-8 mt-16 animate-fade-in-up-delay-2">
      <div class="text-center">
        <div class="text-3xl font-bold text-white">500+</div>
        <div class="text-sm text-white/60">Clients satisfaits</div>
      </div>
      <div class="w-px h-10 bg-white/20 hidden sm:block"></div>
      <div class="text-center">
        <div class="text-3xl font-bold text-white">99.9%</div>
        <div class="text-sm text-white/60">Bactéries éliminées</div>
      </div>
      <div class="w-px h-10 bg-white/20 hidden sm:block"></div>
      <div class="text-center">
        <div class="text-3xl font-bold text-white">100%</div>
        <div class="text-sm text-white/60">Écologique</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out both;
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out both;
    animation-delay: 0.2s;
  }
  .animate-fade-in-up-delay {
    animation: fadeInUp 0.8s ease-out both;
    animation-delay: 0.4s;
  }
  .animate-fade-in-up-delay-2 {
    animation: fadeInUp 0.8s ease-out both;
    animation-delay: 0.6s;
  }
</style>
